{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "maxDuration": 10,
      "runtime": "nodejs18.x"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "DATABASE_PATH": "/tmp/togoevents.db"
  },
  "build": {
    "env": {
      "VITE_API_URL": "https://togoevent-backend.vercel.app"
    }
  },
  "framework": null,
  "outputDirectory": "frontend/build",
  "installCommand": "cd frontend && npm install",
  "buildCommand": "cd frontend && npm run build"
}
