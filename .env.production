# Production
NODE_ENV=production

# API Configuration
VITE_API_URL=https://togoevent-backend.vercel.app
REACT_APP_API_URL=/api

# Database (pour Vercel, utilise /tmp)
DATABASE_PATH=/tmp/togoevents.db

# Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# App Configuration
REACT_APP_NAME=TogoEvents
REACT_APP_VERSION=1.0.0
REACT_APP_DESCRIPTION=Plateforme N°1 de la billetterie événementielle culturelle au Togo
